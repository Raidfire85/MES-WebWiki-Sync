{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build",
      "type": "process",
      "command": "${env:ProgramFiles}\\nodejs\\npm.cmd",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    }
  ]
}
